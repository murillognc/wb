# WaterBrain backend configuration
# Copy to `.env` (the Settings page in the app also writes this file for you).

# Required: your Anthropic API key (sk-ant-...). The app's Settings page can
# set this for you; you don't have to edit this file by hand.
ANTHROPIC_API_KEY=

# Optional debug valves --------------------------------------------------------

# Expose Claude's reasoning in the chat. OFF for production (board-facing).
ANTHROPIC_DISPLAY_THINKING=false

# Append a cache hit/miss + token block to each reply.
WB_SHOW_CACHE_INFO=true

# API request timeout in seconds (thinking can take a while).
ANTHROPIC_REQUEST_TIMEOUT=600

# Logging: INFO by default; DEBUG to see more.
LOG_LEVEL=INFO
